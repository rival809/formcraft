# ─── SALIN FILE INI KE .env DAN ISI SEMUA NILAINYA ──────────────────────────
# cp .env.gcp.example .env && nano .env

# ─── Database ────────────────────────────────────────────────────────────────
# Ganti 'password' dengan password kuat
DATABASE_URL="postgresql://formcraft:GANTI_PASSWORD_KUAT@postgres:5432/formcraft_db"
POSTGRES_PASSWORD="GANTI_PASSWORD_KUAT"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://redis:6379"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET="GANTI_DENGAN_RANDOM_STRING_32_KARAKTER"
# Ganti dengan IP publik VM Anda (atau domain nanti)
BETTER_AUTH_URL="http://GANTI_IP_PUBLIK_VM"

# Google OAuth (opsional — isi jika mau login Google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Storage (MinIO) ─────────────────────────────────────────────────────────
# MinIO berjalan di VM yang sama, port 9000
S3_ENDPOINT="http://minio:9000"
S3_ACCESS_KEY="GANTI_MINIO_USER"
S3_SECRET_KEY="GANTI_MINIO_PASSWORD_KUAT"
S3_BUCKET="formcraft"
S3_REGION="us-east-1"
# Untuk presigned URL yang diakses browser — pakai IP publik
S3_PUBLIC_URL="http://GANTI_IP_PUBLIK_VM:9000/formcraft"

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# Opsi 1: Gmail SMTP
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="email@gmail.com"
# SMTP_PASS="app_password_gmail"

# Opsi 2: Mailgun / SendGrid / Resend
# SMTP_HOST="smtp.mailgun.org"
# SMTP_PORT="587"
# SMTP_USER="postmaster@yourdomain.com"
# SMTP_PASS="your_smtp_key"

# Opsi 3: Matikan dulu (tidak kirim email)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@formcraft.local"

# ─── App ─────────────────────────────────────────────────────────────────────
# Ganti dengan IP publik VM Anda
NEXT_PUBLIC_APP_URL="http://GANTI_IP_PUBLIK_VM"
API_URL="http://api:4000"
API_INTERNAL_SECRET="GANTI_INTERNAL_SECRET"

# ─── Sentry (opsional) ───────────────────────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
