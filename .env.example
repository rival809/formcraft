# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://formcraft:password@localhost:5432/formcraft_db"

# ─── Redis ──────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ───────────────────────────────────────────────
BETTER_AUTH_SECRET="change-me-to-a-random-32-char-string"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Storage (MinIO / S3) ────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="formcraft"
S3_REGION="us-east-1"
S3_PUBLIC_URL="http://localhost:9000/formcraft"

# ─── Email (SMTP) ────────────────────────────────────────
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@formcraft.local"

# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"
API_INTERNAL_SECRET="change-me-internal-api-secret"

# ─── Sentry (optional) ───────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
